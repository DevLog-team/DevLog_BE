### 로그인
POST http://localhost:8080/api/login
Content-Type: application/json

{
  "email": "test2@naver.com",
  "password": "testpw1234"
}

> {%
    const authHeader = response.headers.valueOf("Authorization");

    if (authHeader && authHeader.startsWith("Bearer ")) {
        const accessToken = authHeader.substring(7);
        client.global.set("accessToken", accessToken);
        console.log("AccessToken 저장 완료:", accessToken);
    } else {
        console.error("Authorization 헤더가 존재하지 않거나 형식이 올바르지 않습니다.");
    }

    const cookieHeader = response.headers.valueOf("Set-Cookie");
    if (cookieHeader) {
        // 쿠키 문자열에서 refresh_token 값만 추출 (쿠키 네임이 refreshToken 가정)
        const match = cookieHeader.match(/refreshToken=([^;]+)/);
        if (match) {
            client.global.set("refreshToken", match[1]);
            client.log("RefreshToken 저장 완료");
        }
    }
%}

### 로그아웃
POST http://localhost:8080/api/logout
Content-Type: application/json

### 토큰 재발급
POST http://localhost:8080/api/reissue
Content-Type: application/json